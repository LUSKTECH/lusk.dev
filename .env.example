# =============================================================================
# lusk.dev - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Variables marked [REQUIRED] block the build if missing.
# Variables marked [OPTIONAL] produce a warning if missing.
# =============================================================================

# -----------------------------------------------------------------------------
# Core [REQUIRED]
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SITE_URL=https://lusk.dev

# -----------------------------------------------------------------------------
# Analytics [OPTIONAL]
# -----------------------------------------------------------------------------

NEXT_PUBLIC_GA_ID=

# -----------------------------------------------------------------------------
# Axiom - Observability [OPTIONAL]
# -----------------------------------------------------------------------------

AXIOM_TOKEN=
AXIOM_DATASET=

# -----------------------------------------------------------------------------
# Sentry - Error Tracking [OPTIONAL]
# -----------------------------------------------------------------------------

# Server-side DSN (used by sentry.server.config.ts and sentry.edge.config.ts)
SENTRY_DSN=

# Client-side DSN (used by src/instrumentation-client.ts)
NEXT_PUBLIC_SENTRY_DSN=

# Auth token for source map uploads during build
SENTRY_AUTH_TOKEN=

# Sentry org and project (defaults: lusktech / luskdev)
SENTRY_ORG=
SENTRY_PROJECT=

# -----------------------------------------------------------------------------
# Deployment [OPTIONAL]
# -----------------------------------------------------------------------------

VERCEL_TOKEN=

# -----------------------------------------------------------------------------
# CI Integrations [OPTIONAL] — set as GitHub repository secrets
# -----------------------------------------------------------------------------

LHCI_GITHUB_APP_TOKEN=
CODECOV_TOKEN=
SNYK_TOKEN=
SONAR_TOKEN=
QLTY_COVERAGE_TOKEN=
DISCORD_WEBHOOK_URL=
SEMGREP_APP_TOKEN=
