# =============================================================================
# Lusk Technologies Website Template - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for your project.
# Variables marked [REQUIRED] must be set for the build to succeed.
# Variables marked [OPTIONAL] will produce a warning if missing but won't
# block the build.
# =============================================================================

# -----------------------------------------------------------------------------
# Core (REQUIRED)
# -----------------------------------------------------------------------------

# The public-facing URL of the deployed site (e.g., https://example.com)
NEXT_PUBLIC_SITE_URL=https://lusk.dev

# -----------------------------------------------------------------------------
# Analytics (OPTIONAL)
# -----------------------------------------------------------------------------

# Google Analytics measurement ID (e.g., G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# -----------------------------------------------------------------------------
# Axiom - Log Ingestion & Observability (OPTIONAL)
# -----------------------------------------------------------------------------

# Axiom API token for sending structured logs
AXIOM_TOKEN=

# Axiom dataset name to ingest logs into
AXIOM_DATASET=

# -----------------------------------------------------------------------------
# Sentry - Error Tracking (OPTIONAL)
# -----------------------------------------------------------------------------

# Sentry DSN for error capture (e.g., https://key@sentry.io/project)
# SENTRY_DSN is used server-side; NEXT_PUBLIC_SENTRY_DSN is exposed to the browser
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Sentry auth token for source map uploads during build
SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Discord - CI/CD Notifications (OPTIONAL)
# -----------------------------------------------------------------------------

# Discord webhook URL for sending CI/CD event notifications
DISCORD_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Deployment Platforms (OPTIONAL)
# -----------------------------------------------------------------------------

# Vercel token for preview and production deployments
VERCEL_TOKEN=

# Netlify auth token for preview and production deployments
NETLIFY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Lighthouse CI (OPTIONAL)
# -----------------------------------------------------------------------------

# GitHub App token for Lighthouse CI status checks
LHCI_GITHUB_APP_TOKEN=

# -----------------------------------------------------------------------------
# Code Coverage (OPTIONAL)
# -----------------------------------------------------------------------------

# Codecov token for uploading coverage reports
CODECOV_TOKEN=

# -----------------------------------------------------------------------------
# Security Scanning (OPTIONAL)
# -----------------------------------------------------------------------------

# Set to "true" to enable Trivy vulnerability scanning in CI
TRIVY_ENABLED=

# Snyk token for dependency vulnerability scanning
SNYK_TOKEN=

# Safety CLI API key for Python dependency scanning
SAFETY_API_KEY=

# -----------------------------------------------------------------------------
# Code Quality (OPTIONAL)
# -----------------------------------------------------------------------------

# SonarQube token for code quality analysis
SONAR_TOKEN=

# qlty.sh token for code quality metrics
QLTY_TOKEN=
