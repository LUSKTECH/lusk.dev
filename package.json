{
  "name": "lusk.dev",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint src __tests__",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.53.1",
    "next": "16.2.6",
    "next-axiom": "1.10.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-istanbul": "4.1.6",
    "fast-check": "4.8.0",
    "husky": "9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "16.4.0",
    "oxlint": "^1.66.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
